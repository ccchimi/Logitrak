# Servidor
PORT=4000

# PostgreSQL local
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password_de_postgres
PGDATABASE=logitrak

# Auth
JWT_SECRET=generar_uno_con__node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRA=8h

# RENAPER (Sistema de Identidad Digital). Sin credenciales reales,
# la verificación corre en modo simulado.
RENAPER_API_URL=
RENAPER_API_KEY=
