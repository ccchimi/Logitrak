# =============================================================================
# Logitrak — Backend · Variables de entorno
# -----------------------------------------------------------------------------
# Copiá este archivo a ".env" y completá los valores marcados con  <-- COMPLETAR.
#   Windows PowerShell:  copy .env.example .env
#   Linux / macOS:       cp .env.example .env
# Solo hacen falta DOS cosas para arrancar: DATABASE_URL y JWT_SECRET.
# El resto es opcional: sin esas claves, el sistema corre en modo demo/sandbox.
#
# NOTA SOBRE EL DEPLOY (Render): en producción NO se usa este archivo; las
# variables se cargan en el panel del servicio (Environment). Allá NO definas
# PORT (Render lo asigna solo) y SÍ definí PUBLIC_API_URL con la URL pública.
# =============================================================================

# Puerto donde queda la API (la app del frontend la consume acá).
# En local dejalo en 4000. En Render NO lo definas: la plataforma lo inyecta.
PORT=4000

# URL pública con la que el backend se referencia a sí mismo (la usan los
# pagos para armar los links de callback del QR / MercadoPago). Si queda
# vacía, se deduce del request entrante (sirve en local, pero conviene fijarla).
#   Local:      dejala vacía o http://aqui-va-tu-ip:4000
#   Producción: la URL del backend en Render.
PUBLIC_API_URL=https://logitrak.onrender.com

# -----------------------------------------------------------------------------
# 1) BASE DE DATOS (Supabase)  <-- COMPLETAR (obligatorio)
# -----------------------------------------------------------------------------
# Cómo obtener el valor:
#   1. Entrá al proyecto en https://supabase.com
#   2. Botón "Connect" (arriba) -> pestaña "Connection string"
#   3. Elegí "Session pooler" y tipo "URI"
#   4. Copiá el texto y reemplazá [YOUR-PASSWORD] por la contraseña de la base
# Queda algo así (los corchetes NO van, son solo el marcador):
DATABASE_URL=postgresql://postgres.tu-ref:tu-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# SSL de la conexión a Postgres. Por defecto el backend conecta con SSL, que es
# lo que Supabase exige, así que no hace falta tocar nada. Solo cambialo si
# corrés un Postgres local SIN SSL:
# PGSSL=false
# Verificación estricta del certificado (déjalo en false para Supabase):
# PGSSL_STRICT=false

# -----------------------------------------------------------------------------
# 2) AUTENTICACIÓN  <-- COMPLETAR (obligatorio)
# -----------------------------------------------------------------------------
# Clave secreta para firmar los tokens de sesión (JWT). Generá una propia con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=pega_aqui_tu_clave_generada
JWT_EXPIRA=8h

# -----------------------------------------------------------------------------
# 3) OPCIONALES — dejenlos vacios para probar el sistema
# -----------------------------------------------------------------------------
# Si quedan en blanco, todo funciona igual en modo demo:
#   · Verificación de identidad: OFFLINE (lee el código PDF417 del dorso del DNI).
#   · Pagos: el QR cae a un sandbox que se aprueba desde la app y la tarjeta
#     usa un procesador SIMULADO (nunca cobra de verdad).

# Verificación de identidad contra RENAPER (si está vacío -> modo offline).
RENAPER_API_URL=
RENAPER_API_KEY=

# Comparación facial / prueba de vida. En "true" exigen que la selfie coincida
# y que haya liveness; déjenlos sin definir para no bloquear las pruebas.
# FACE_MATCH_REQUERIDO=false
# LIVENESS_REQUERIDO=false
# Carpeta con los modelos de face-api (por defecto: backend/models).
# FACE_MODELS_DIR=

# Pagos con MercadoPago (si está vacío -> sandbox simulado).
MP_ACCESS_TOKEN=

# Pagos con MODO (si está vacío -> sandbox simulado). Las *_URL son opcionales:
# si no se definen, se derivan de MODO_API_URL.
MODO_API_URL=
MODO_CLIENT_ID=
MODO_CLIENT_SECRET=
MODO_STORE_ID=
# MODO_TOKEN_URL=
# MODO_INTENTION_URL=
# MODO_STATUS_URL=
