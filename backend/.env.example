# Servidor
PORT=4000

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Opción A — Local (servicio de Windows). SSL apagado.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password_de_postgres
PGDATABASE=logitrak

# Opción B — Azure Database for PostgreSQL (Flexible Server).
# Comentá la Opción A y completá estos valores con los de tu servidor de Azure.
# El usuario es solo el nombre del admin (Flexible Server NO usa el sufijo
# "@servidor" del viejo Single Server).
# PGHOST=logitrak-db.postgres.database.azure.com
# PGPORT=5432
# PGUSER=logitrakadmin
# PGPASSWORD=tu_password_de_azure
# PGDATABASE=logitrak
# PGSSLMODE=require          # Azure exige TLS; esto prende SSL en el backend.
# PGSSL_INSECURE=false       # poné true SOLO si tenés un error de certificado.

# Auth
JWT_SECRET=generar_uno_con__node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRA=8h

# RENAPER (Sistema de Identidad Digital). Sin credenciales reales, la
# verificación de identidad corre en modo OFFLINE (lectura del PDF417 del DNI).
RENAPER_API_URL=
RENAPER_API_KEY=

# ---------------------------------------------------------------------------
# Pagos / facturación
# ---------------------------------------------------------------------------
# Sandbox-first: sin credenciales, los pagos por QR (Mercado Pago / MODO) corren
# simulados y se aprueban desde la pantalla de checkout. La tarjeta SIEMPRE es
# un procesador simulado (no toca ninguna pasarela). Completá estas variables
# para cobrar de verdad.

# Mercado Pago (Checkout Pro). Con el access token, el checkout crea una
# preferencia real y el cobro lo confirma MP por webhook.
MP_ACCESS_TOKEN=

# MODO (pago por QR/deeplink). Requiere onboarding de comercio.
MODO_API_URL=
MODO_API_KEY=

# URL pública del backend, para armar la notification_url del webhook de MP.
# En local con MP real, exponé el puerto con ngrok y pegá la URL acá.
# PUBLIC_API_URL=https://tu-tunel.ngrok-free.app

# Verificación de identidad del alta de chofer. Por defecto: PDF417 + cruce de
# datos + selfie (Tier 1). Los enforcement quedan apagados para no romper Expo
# Go / web; activalos solo cuando tengas el dev build (liveness) o el runtime
# de face-api (match facial). Ver "Verificación de identidad" en el README.
# LIVENESS_REQUERIDO=false      # true: exige la prueba de vida (Tier 2, dev build)
# FACE_MATCH_REQUERIDO=false    # true: exige coincidencia selfie↔DNI (Tier 3)
# FACE_MODELS_DIR=              # ruta a los pesos de face-api (default: backend/models)
