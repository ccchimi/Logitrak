EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your_android_maps_key_here
EXPO_PUBLIC_GOOGLE_DIRECTIONS_KEY=your_directions_key_here
EXPO_PUBLIC_GOOGLE_MAPS_WEB_KEY=your_web_maps_key_here

# URL del backend. Si no se define, se resuelve desde Metro (falla en modo
# tunnel y a veces en emulador). Recomendado fijarla a la IP LAN de tu PC para
# que ande en web, emulador Android e iPhone por igual. Ej:
# EXPO_PUBLIC_API_URL=http://192.168.1.70:4000 -- ejemplo no es veridico
EXPO_PUBLIC_API_URL=

